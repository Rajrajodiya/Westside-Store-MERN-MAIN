# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# === Required: MongoDB ===
# Get a free cluster at https://mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/westside-store?retryWrites=true&w=majority

# === Required: JWT ===
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here

# === Optional: Email (for order confirmations & password reset) ===
# Use Resend (free tier): https://resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxx
SMTP_FROM=orders@westside-store.com

# === Optional: Stripe (for card payments - mock mode if not set) ===
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=

# === Optional: CORS ===
CORS_ORIGIN=https://your-app.vercel.app,*
